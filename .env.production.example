# ══════════════════════════════════════════════════════════════════════════════
# NEXYA BACKEND — .env.production  (TEMPLATE)
# ══════════════════════════════════════════════════════════════════════════════
#
# Ce fichier .example est COMMITÉ dans git (placeholders uniquement).
# Le vrai .env.production (rempli avec les VRAIS secrets) ne l'est JAMAIS :
# il est gitignored. Procédure : copier ce fichier en `.env.production` sur le
# VPS, puis le remplir (phase D7 du déploiement).
#
# Placeholders :
#   __A_GENERER__  = valeur produite par scripts/generate-secrets.sh
#   __A_REMPLIR__  = clé récupérée sur un compte externe (cf. checklist §4)
#
# RÈGLES IMPORTANTES :
#   - Les valeurs marquées « (même valeur que …) » DOIVENT être identiques.
#   - Tous les secrets sont générés en hexadécimal (URL-safe) → pas d'échappement
#     à prévoir dans les URLs de connexion.
#   - Le validateur Settings._enforce_production_safety (app/config.py) REFUSE
#     le démarrage de l'API si une de ces variables est absente/incorrecte.
# ══════════════════════════════════════════════════════════════════════════════

# ── APP ───────────────────────────────────────────────────────────────────────
ENV=production
DEBUG=false
APP_SECRET=__A_GENERER__
APP_VERSION=v1.0.0
APP_COMMIT_SHA=
SECURITY_HEADERS_PRESET=prod
# Origines CORS explicites — JAMAIS `*` en production (le validateur refuse).
ALLOWED_ORIGINS=https://nexyalabs.com

# ── BASE DE DONNÉES (conteneur postgres, réseau docker interne) ───────────────
# IMPORTANT : driver `psycopg` (PAS `asyncpg` — bugué sur Python 3.14).
# Le mot de passe dans DATABASE_URL == POSTGRES_PASSWORD ci-dessous.
DATABASE_URL=postgresql+psycopg://nexya:__A_GENERER__@postgres:5432/nexya
POSTGRES_USER=nexya
POSTGRES_PASSWORD=__A_GENERER__
POSTGRES_DB=nexya
DB_ECHO=false

# ── REDIS (conteneur redis, réseau docker interne) ────────────────────────────
# Le mot de passe dans REDIS_URL == REDIS_PASSWORD ci-dessous.
REDIS_URL=redis://:__A_GENERER__@redis:6379/0
REDIS_PASSWORD=__A_GENERER__

# ── JWT (RS256 — fichiers .pem montés en lecture seule dans le conteneur) ─────
# generate-secrets.sh produit jwt_private.pem + jwt_public.pem dans secrets/.
JWT_PRIVATE_KEY=/app/secrets/jwt_private.pem
JWT_PUBLIC_KEY=/app/secrets/jwt_public.pem

# ── STOCKAGE OBJET (conteneur minio, réseau docker interne) ───────────────────
# S3_ACCESS_KEY / S3_SECRET_KEY servent AUSSI de creds root MinIO
# (MINIO_ROOT_USER / MINIO_ROOT_PASSWORD dans docker-compose.prod.yml).
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=__A_GENERER__
S3_SECRET_KEY=__A_GENERER__
S3_BUCKET_NAME=nexya-media
S3_USE_SSL=false
STORAGE_AUTO_CREATE_BUCKET=true

# ── PROVIDER IA — Gemini (NIVEAU 1, indispensable) ────────────────────────────
GEMINI_API_KEY=__A_REMPLIR__
GEMINI_USE_VERTEX=false

# ── PROVIDERS IA secondaires (NIVEAU 2/3 — sinon Mock automatique) ────────────
OPENAI_API_KEY=__A_REMPLIR__
ANTHROPIC_API_KEY=

# ── EMAIL — Brevo (NIVEAU 2 — sinon les emails sont loggés, pas envoyés) ──────
BREVO_API_KEY=__A_REMPLIR__
BREVO_SENDER_EMAIL=no-reply@nexyalabs.com
BREVO_SENDER_NAME=NEXYA

# ── hCAPTCHA (NIVEAU 2 — anti-bot à l'inscription) ────────────────────────────
HCAPTCHA_ENABLED=true
HCAPTCHA_SECRET_KEY=__A_REMPLIR__
HCAPTCHA_SITE_KEY=__A_REMPLIR__

# ── PUSH FCM (NIVEAU 2 — sinon push simulés) ──────────────────────────────────
# Déposer le JSON service account Firebase dans secrets/fcm-service-account.json.
FCM_SERVICE_ACCOUNT_FILE=/app/secrets/fcm-service-account.json

# ── OBSERVABILITÉ ─────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
PROMETHEUS_SCRAPE_TOKEN=__A_GENERER__
GRAFANA_ADMIN_PASSWORD=__A_GENERER__
SENTRY_DSN=__A_REMPLIR__
SENTRY_ENVIRONMENT=production
OTEL_ENABLED=false

# ── RGPD / AI Act (le validateur exige AU MOINS un email — fail-fast sinon) ───
# FORMAT OBLIGATOIRE : tableau JSON (RGPD_ADMIN_EMAILS est typé list[str] —
# pydantic-settings parse cette variable en JSON). Une valeur non-JSON fait
# CRASHER le boot avant même le validateur prod.
#   Correct   : RGPD_ADMIN_EMAILS=["ivan@nexyalabs.com"]
#   Plusieurs : RGPD_ADMIN_EMAILS=["dpo@nexyalabs.com","ivan@nexyalabs.com"]
RGPD_ADMIN_EMAILS=["__A_REMPLIR__"]

# ── C2PA — désactivé en V1 (pas de clés X.509 — voir app/features/images/c2pa.py)
# Tant que C2PA_ENABLED=false, le validateur n'exige aucune clé de signature.
C2PA_ENABLED=false

# ── URLs publiques (deep links dans les emails) ───────────────────────────────
FRONTEND_PASSWORD_RESET_URL=https://app.nexyalabs.com/reset-password
FRONTEND_UNSUBSCRIBE_URL=https://app.nexyalabs.com/unsubscribe

# ── RUNTIME ───────────────────────────────────────────────────────────────────
# Nombre de workers uvicorn — aligné sur les 4 vCPU du VPS CX32.
WEB_CONCURRENCY=4

# ── IMAGE DOCKER (généralement géré par scripts/deploy.sh) ────────────────────
# GHCR_OWNER : propriétaire du registry. Défaut `nexya-ai` dans le compose.
# IMAGE_TAG  : tag de version déployé — `export IMAGE_TAG=vX.Y.Z` par deploy.sh.
# GHCR_OWNER=nexya-ai
# IMAGE_TAG=v1.0.0

# >>> LONGUE TRAÎNE — toutes les autres variables (quotas Free/Pro, timeouts,
# >>> rate limits, Voice/Vision/Documents, pricing…) gardent leurs défauts
# >>> définis dans app/config.py. Référence exhaustive : nexya_backend/.env.example
# >>> (474 lignes). Ne surcharger ici QUE si un défaut doit être changé en prod.
