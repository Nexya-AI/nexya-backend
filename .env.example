# ══════════════════════════════════════════════════════════════
# NEXYA Backend — Variables d'environnement
# Copier ce fichier : cp .env.example .env
# Remplir les valeurs réelles. Ne JAMAIS committer le .env.
# ══════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────
ENV=development
APP_SECRET=change-me-to-a-random-64-char-string
DEBUG=true

# ── Database (PostgreSQL 16 + pgvector) ────────────────────────
DATABASE_URL=postgresql+asyncpg://nexya:nexya_dev@localhost:5432/nexya

# ── Redis 7 ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT RS256 ──────────────────────────────────────────────────
# Générer les clés :
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#
# Deux options :
# 1. (Recommandé dev) Chemin vers le fichier .pem — le backend lit le contenu :
#      JWT_PRIVATE_KEY=private.pem
#      JWT_PUBLIC_KEY=public.pem
# 2. (Prod) Coller le contenu PEM brut (commence par -----BEGIN).
JWT_PRIVATE_KEY=private.pem
JWT_PUBLIC_KEY=public.pem

# ── IA — Gemini (Vertex AI) ───────────────────────────────────
GEMINI_API_KEY=
GCP_PROJECT_ID=nexya-ai
GCP_LOCATION=us-central1

# ── IA — OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=

# ── Embeddings — sélection provider (G1) ─────────────────────
# 'auto' (défaut) : Gemini si clé seule dispo, sinon OpenAI, sinon Mock.
# 'gemini' / 'openai' / 'mock' : override explicite.
EMBEDDINGS_PROVIDER=auto
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ── Vertex AI vs AI Studio (embeddings Gemini) ───────────────
# Par défaut (false), Gemini embeddings utilisent AI Studio via GEMINI_API_KEY.
# Passer à true pour router via Vertex AI (utile si crédits sur GCP / free
# trial $300). En mode Vertex, ignorer GEMINI_API_KEY et s'appuyer sur
# `gcloud auth application-default login` (Application Default Credentials).
GEMINI_USE_VERTEX=false
GCP_PROJECT_ID=
GCP_REGION=us-central1

# ── Corpus Experts RAG (G1) ──────────────────────────────────
EXPERT_CORPUS_ENABLED=true
EXPERT_CORPUS_EMBEDDING_DIM=768
EXPERT_CORPUS_K=5
EXPERT_CORPUS_MIN_SIMILARITY=0.7
EXPERT_CORPUS_MAX_CHARS=3000
TATOEBA_SENTENCES_URL=https://downloads.tatoeba.org/exports/sentences.tar.bz2
TATOEBA_LINKS_URL=https://downloads.tatoeba.org/exports/links.tar.bz2

# ── IA — Qwen (Alibaba Cloud) ────────────────────────────────
QWEN_API_KEY=

# ── Storage (MinIO / S3) ──────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=nexya_minio
S3_SECRET_KEY=nexya_minio_secret
S3_BUCKET_NAME=nexya-media

# ── Paiements Afrique ─────────────────────────────────────────
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
NOTCHPAY_PUBLIC_KEY=
NOTCHPAY_SECRET_KEY=

# ── Paiements carte bancaire ──────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Notifications push FCM (Session F2) ──────────────────────
# Firebase Cloud Messaging HTTP v1 avec OAuth2 service account.
# Pattern mock-first : si NI `FCM_SERVICE_ACCOUNT_JSON` NI
# `FCM_SERVICE_ACCOUNT_FILE` n'est renseigné, le backend bascule sur
# `MockFCMProvider` (aucun push réel). Un warning « ⚠️ FCM en mode
# Mock — PROD non opérationnel » est émis au boot pour rappeler la
# bascule à faire avant déploiement prod.
#
# Où obtenir le service account JSON :
#   Firebase Console → Project Settings → Service Accounts
#   → « Generate new private key » → télécharger le .json.
#
# Deux formats au choix :
# 1. `FCM_SERVICE_ACCOUNT_FILE` = chemin vers le .json (recommandé dev).
# 2. `FCM_SERVICE_ACCOUNT_JSON` = contenu brut échappé sur une ligne
#    (pratique pour variables d'env prod, Docker secrets).
# Si les deux sont posés, `_JSON` prime.
FCM_SERVER_KEY=
FCM_SERVICE_ACCOUNT_JSON=
FCM_SERVICE_ACCOUNT_FILE=
FCM_PROJECT_ID=
FCM_MOCK_ENABLED=false
FCM_PUSH_TIMEOUT_SECONDS=10
FCM_BODY_PREVIEW_MAX_CHARS=140

# ── Chat — function calling tools LLM (Session F2) ────────────
# Cap dur sur le nombre de rounds tool_calls autorisés dans une
# même requête `/chat/stream`. 5 = largement suffisant pour un
# cas légitime (« rappelle-moi X demain » = 1 round), coupe les
# boucles infinies où le LLM s'obstinerait.
CHAT_MAX_TOOL_ROUNDS=5

# ── Notifications dispatcher (Session F3) ─────────────────────
# Kill-switch global du fallback email si push KO. Laisser True
# en prod (UX optimale), désactiver temporairement si la facture
# email Brevo explose.
NOTIFICATION_FALLBACK_EMAIL_ENABLED=true
# Nb tentatives push avant bascule email (couvre le retry FCM).
NOTIFICATION_MAX_ATTEMPTS_PUSH=3
# TTL du JWT unsubscribe (365j). CAN-SPAM impose 10j min, RGPD
# exige unsubscribe « à tout moment ». 365j honore les deux.
NOTIFICATION_UNSUBSCRIBE_TOKEN_TTL_DAYS=365
# URL publique de la page unsubscribe Flutter/web. Mobile =
# scheme nexya://unsubscribe?token=..., web fallback = HTTPS.
FRONTEND_UNSUBSCRIBE_URL=https://app.nexya.ai/unsubscribe
# Rate limit IP sur POST /notifications/unsubscribe/{token}.
# Anti-brute-force de tokens (endpoint public sans auth).
UNSUBSCRIBE_RATE_LIMIT_PER_HOUR=10

# ── Email transactionnel (Brevo / ex-Sendinblue) ──────────────
# Si BREVO_API_KEY est vide, le backend utilise un MockEmailService
# qui logge les emails au lieu de les envoyer (dev/test friendly).
# Créer un compte : https://www.brevo.com → SMTP & API → Créer clé API v3
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@nexya.ai
BREVO_SENDER_NAME=NEXYA

# URL publique de la page de reset password — le backend construit
# `{url}?token={jwt}` et l'envoie dans l'email. En mobile, le Flutter
# intercepte le scheme `nexya://` ; la version web fallback sur HTTPS.
FRONTEND_PASSWORD_RESET_URL=https://app.nexya.ai/reset-password

# ── Captcha (hCaptcha — anti-bot à l'inscription) ─────────────
# Si HCAPTCHA_SECRET_KEY est vide OU HCAPTCHA_ENABLED=false,
# le backend utilise un MockCaptchaVerifier (accepte "mock-success",
# rejette "mock-fail"). Clés réelles sur https://www.hcaptcha.com
# → Dashboard → Sites → New Site → récupérer site_key + secret_key.
HCAPTCHA_ENABLED=true
HCAPTCHA_SECRET_KEY=
HCAPTCHA_SITE_KEY=

# ── Anti-abus : quotas device & IP ────────────────────────────
# Inscription : chaque device (header X-Device-Id) ne peut créer
# que N comptes par fenêtre de 24 h. Couche IP : N comptes/jour/IP.
# Ajuster prudemment — trop bas = faux positifs (Wi-Fi d'école,
# café, NAT carrier mobile). Trop haut = fermes d'inscriptions.
DEVICE_REGISTRATION_DAILY_LIMIT=3
REGISTER_DAILY_IP_LIMIT=5
CHAT_MESSAGE_PER_MINUTE_LIMIT=100

# ── Documents RAG (Bloc D4) ───────────────────────────────────
# PRICING — provisoire, à trancher par Ivan lors du pricing final.
# Ces 4 valeurs définissent l'offre commerciale (ce qu'un Free peut
# faire, ce qu'un Pro débloque). Démarrées sur des valeurs raisonnables
# pour ne pas bloquer le dev, doivent être validées avant prod.
DOCUMENTS_MAX_FREE=3
DOCUMENTS_MAX_PRO=50
DOCUMENTS_CHUNKS_PER_FILE_MAX=500
MAX_CONCURRENT_CHUNKING_PER_USER=2

# TECHNIQUE — à la main du backend (calibrage algo, non-commercial).
DOCUMENTS_CHUNK_TARGET_TOKENS=500
DOCUMENTS_CHUNK_OVERLAP_TOKENS=50
DOCUMENTS_EMBED_BATCH_SIZE=100
DOCUMENTS_PRE_CLEAN_MIN_CHARS=50
DOCUMENTS_CHUNKING_SEMAPHORE_TTL_SECONDS=600

# ── RAG query (Bloc D5) ───────────────────────────────────────
# TECHNIQUE — calibrage anti-abus, pas valeur pricing commerciale.
# 60/h couvre un power-user légitime. Distinct du budget embeddings
# journalier — les deux cohabitent.
RAG_QUERY_RATE_LIMIT_PER_HOUR=60

# ── Voice (Bloc E1) — Pro only ────────────────────────────────
# Stratégie : Free = STT/TTS natif Flutter offline ($0 backend).
# Pro = endpoints gated `require_pro` appelant Whisper/OpenAI TTS.
# Un Free qui tape /voice/* → 403 PLAN_REQUIRED immédiat.
#
# PRICING — provisoire à trancher avant prod
VOICE_MINUTES_PRO_PER_DAY=120
VOICE_TTS_CHARS_PRO_PER_DAY=50000

# TECHNIQUE — calibrage non-commercial
VOICE_MAX_UPLOAD_BYTES=20971520
VOICE_MAX_DURATION_SECONDS=600
VOICE_TRANSCRIBE_RATE_LIMIT_PER_HOUR=30
VOICE_TTS_RATE_LIMIT_PER_HOUR=60
VOICE_MOCK_ENABLED=false
VOICE_DEFAULT_STT_MODEL=whisper-1
VOICE_DEFAULT_TTS_MODEL=tts-1
VOICE_DEFAULT_VOICE=alloy

# ── Vision (Bloc E2) — Free + Pro asymétrie par tier ──────────
# Free : tier 'flash' imposé (Gemini 2.0 Flash, cheap).
# Pro  : tier 'flash' ou 'pro' (Gemini 2.0 Pro ou GPT-4o au choix).
#
# PRICING — provisoire à trancher avant prod
VISION_IMAGES_FREE_PER_DAY=3
VISION_IMAGES_PRO_PER_DAY=50
VISION_MAX_IMAGES_PER_REQUEST=4
VISION_MAX_OUTPUT_TOKENS_PRO=4096

# TECHNIQUE — calibrage non-commercial
VISION_MAX_IMAGE_BYTES=10485760
VISION_MAX_DIMENSION=2048
VISION_MAX_INPUT_TOKENS_PER_REQUEST=10000
VISION_RATE_LIMIT_PER_HOUR=30
VISION_MOCK_ENABLED=false
VISION_DEFAULT_FLASH_MODEL=gemini-2.0-flash
VISION_DEFAULT_PRO_MODEL=gemini-2.0-pro
VISION_PRO_PROVIDER=gemini

# ── Images watermark (Bloc E4) ────────────────────────────────
# Watermark visuel NEXYA (logo oiseau bleu) sur images générées.
# Retirable par users Pro moyennant surcoût (prep wallet v2).
#
# PRICING — provisoire à trancher au pricing final
IMAGE_NO_WATERMARK_PRICE_MULTIPLIER=2.0

# TECHNIQUE — calibrage non-commercial
IMAGE_WATERMARK_SCALE_RATIO=0.12
IMAGE_WATERMARK_OPACITY=0.70

# ── Planner Scheduler (Bloc F1) ───────────────────────────────
# Tâches IA planifiées. CRUD /tasks + workers arq.
#
# PRICING — provisoire à trancher avant prod
TASKS_MAX_FREE=3
TASKS_MAX_PRO=50

# TECHNIQUE — calibrage non-commercial
TASKS_MIN_INTERVAL_MINUTES=5
TASKS_RESULTS_RETENTION_DAYS=30
TASKS_DISPATCH_BATCH_SIZE=50
TASKS_MAX_TITLE_CHARS=200
TASKS_MAX_PROMPT_CHARS=4000

# ── Observabilité prod (Session K1) ──────────────────────────
# Trois piliers complémentaires : OpenTelemetry (traces) + Sentry
# (exceptions) + Prometheus (métriques). Chaque pilier s'active
# avec une seule env var, le code reste agnostique de la cible.

# Version applicative — utilisée par Sentry pour le release tracking
# et par OTel comme `service.version`. Posée par CI/CD en prod
# (ex: `APP_VERSION=v0.1.0+sha.abc1234`). Défaut "dev" en local.
APP_VERSION=dev

# ── OpenTelemetry tracing ────────────────────────────────────
# Kill-switch global. False (défaut) = aucune instrumentation,
# zéro overhead. Poser True après que le collecteur OTLP cible
# (Jaeger/Tempo/Honeycomb) soit déployé et joignable.
OTEL_ENABLED=false
# Endpoint OTLP/HTTP du collecteur (port 4318 standard). Si
# l'endpoint est inaccessible, le SDK envoie en silence vers le
# rien (fail-open, un seul warning au boot — le service ne crashe
# JAMAIS à cause d'OTel).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Nom du service tel qu'il apparaîtra dans Jaeger/Tempo.
OTEL_SERVICE_NAME=nexya-backend
# Ratio de sampling — défaut 10 % en prod (économie facture OTLP).
# Poser 1.0 en dev pour 100 % visibilité. Le ParentBased respecte
# la décision parent si un upstream a déjà sampled.
OTEL_TRACES_SAMPLER_RATIO=0.1
# Inclusion du user_id dans les attributs span (RGPD : off par
# défaut, à activer ponctuellement pour debug ciblé).
OTEL_LOG_USER_IDS=false

# ── Sentry exceptions + breadcrumbs ──────────────────────────
# DSN vide (défaut) = Sentry désactivé silencieux (zéro outbound).
# Créer le compte plus tard sur https://sentry.io → projet
# « nexya-backend » → récupérer DSN. Free tier = 5k events/mois.
SENTRY_DSN=
# Environnement Sentry (development|staging|production).
SENTRY_ENVIRONMENT=development
# Sample rate APM (en plus des events). 5 % en prod = trade-off
# coût/visibilité. 0.0 désactive complètement.
SENTRY_TRACES_SAMPLE_RATE=0.05
# Profiling continu — désactivé V1 (coût + maturité Python 2026).
SENTRY_PROFILES_SAMPLE_RATE=0.0

# ── Prometheus métriques applicatives ────────────────────────
# Activation de la collecte custom + endpoint /metrics. Coût zéro
# côté client, scrape pull-based externe.
PROMETHEUS_ENABLED=true
# Path de l'endpoint /metrics. Configurable si on veut le placer
# derrière /internal/metrics ou autre namespace privé.
PROMETHEUS_METRICS_PATH=/metrics
# Token d'auth pour le scraper Prometheus. Vide en dev = endpoint
# ouvert avec WARNING au boot. Vide en prod = ValueError fail-fast
# (un endpoint /metrics ouvert en prod expose les KPI métier).
PROMETHEUS_SCRAPE_TOKEN=

# ── Logging — injection contexte OTel ────────────────────────
# Quand True (défaut), chaque log structlog porte automatiquement
# trace_id + span_id du span OTel actif (corrélation logs↔traces).
OBSERVABILITY_LOG_TRACE_INJECTION=true

# ── RGPD + AI Act (Session J1) ───────────────────────────────
# Conformité RGPD UE 2016/679 (Articles 7, 15, 17, 20) + AI Act UE
# 2024/1689 applicable août 2026 (Article 13 — registre des IA).
#
# Délai de grâce entre demande de suppression et hard delete physique.
# 30j = recommandation CNIL. Permet la rétractation user via
# POST /rgpd/user/account/delete-request/cancel. PROVISOIRE — Ivan
# ajustera selon stratégie produit (7j possible mais friction UX).
RGPD_DELETION_GRACE_PERIOD_DAYS=30
# Cap soft sur la taille du ZIP RGPD. PROVISOIRE — Ivan ajustera selon
# profil moyen utilisateur observé en prod.
RGPD_EXPORT_MAX_SIZE_BYTES=104857600
# Rate limit user-scope sur GET /rgpd/user/data-export.
RGPD_EXPORT_RATE_LIMIT_PER_24H=1
# TTL presigned URLs blobs MinIO dans le ZIP (7 jours).
RGPD_BLOB_PRESIGNED_TTL_SECONDS=604800
# Liste comma-separated d'emails autorisés sur /rgpd/admin/* — vide
# en prod = ValueError fail-fast au boot. Au minimum l'email DPO
# d'Ivan en V1, prévoir DPO externe pour 950k users en V2.
RGPD_ADMIN_EMAILS=

# ── N1 — Endpoints divers (feedback + suggestions + models) ─
# Email de l'équipe NEXYA recevant les suggestions user via
# POST /suggestions. Recommandation prod : créer un alias
# `feedback@nexya.ai` qui pointe vers la boîte d'Ivan / DPO V1,
# remplacer par une mailing-list équipe Phase 14.
FEEDBACK_TEAM_EMAIL=feedback@nexya.ai
# Anti-spam suggestions user (5 submits/jour/user, sliding window 24h).
SUGGESTIONS_RATE_LIMIT_PER_DAY=5
# Rate limit feedback chat user-scoped (60/h sliding window). Plus
# large que suggestions car les thumbs up/down sont rapides.
FEEDBACK_RATE_LIMIT_PER_HOUR=60
# TTL Cache-Control: max-age= du GET /models côté client (5 min).
MODELS_ENDPOINT_CACHE_TTL_SECONDS=300

# ── Grafana + Prometheus dev (Session K2) ────────────────────
# Variables consommées UNIQUEMENT par le compose
# `docker/docker-compose.observability.yml` (Grafana + Prometheus
# locaux) — le backend NEXYA ne les utilise pas au runtime, à
# l'exception du garde-fou production safety qui refuse un mot
# de passe admin Grafana faible.
#
# Mot de passe admin Grafana en dev (login http://localhost:3000
# avec admin / GRAFANA_ADMIN_PASSWORD). En prod : OBLIGATOIRE de
# poser un mot de passe fort via secret manager (Hetzner vault,
# AWS SSM, doppler, etc.). Vide ou "admin" en prod = ValueError
# fail-fast au boot du backend.
GRAFANA_ADMIN_PASSWORD=admin
# Période de scrape Prometheus → /metrics du backend. 15 s = standard.
PROMETHEUS_SCRAPE_INTERVAL_SECONDS=15
# Seuil USD/jour déclenchant l'alerte `NexyaCostUSDDailyExceeded`.
# Valeur PROVISOIRE — à affiner par Ivan selon le budget IA prod
# réel (50 USD = signal d'attaque/abus sur 950k users worst-case,
# 500 USD = mode normal high-volume). TODO(Ivan).
COST_USD_DAILY_ALERT_THRESHOLD=100.0

# ── Phase 18 — Crisp + Helpdesk (Session N4 volet B) ──────────
# Escalation auto vers Crisp (chat support) quand un user Pro
# rencontre un incident critique (paiement, LLM down).
# Mock-first auto si CRISP_API_KEY ou CRISP_WEBSITE_ID vide.
CRISP_WEBSITE_ID=
CRISP_IDENTIFIER=plugin
CRISP_API_KEY=
CRISP_ESCALATION_ENABLED=true

# ── Tests de charge k6 (Session N4 volet A) ────────────────────
# Sanity caps (anti-runaway) — relus côté tests/load/run.sh.
LOAD_TEST_MAX_VUS=100
LOAD_TEST_DEFAULT_DURATION_SECONDS=60

# ── Évals IA reproductibles (Session N3) ──────────────────────
# Modèle utilisé par GeminiJudge dans `tests/evals/`.
EVALS_JUDGE_MODEL=gemini-2.5-pro
# Seuil en pp pour détecter une régression de qualité IA.
# PR (mock judge) = 10pp / Nightly (Gemini judge) = 5pp.
EVALS_REGRESSION_THRESHOLD_PP=10.0
# Sanity check anti-corpus-vide.
EVALS_CORPUS_MIN_SIZE=100

# ── CORS ───────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
