# ══════════════════════════════════════════════════════════════
# NEXYA Backend — Variables d'environnement
# Copier ce fichier : cp .env.example .env
# Remplir les valeurs réelles. Ne JAMAIS committer le .env.
# ══════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────
ENV=development
APP_SECRET=change-me-to-a-random-64-char-string
DEBUG=true

# ── Database (PostgreSQL 16 + pgvector) ────────────────────────
DATABASE_URL=postgresql+asyncpg://nexya:nexya_dev@localhost:5432/nexya

# ── Redis 7 ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT RS256 ──────────────────────────────────────────────────
# Générer les clés :
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#
# Deux options :
# 1. (Recommandé dev) Chemin vers le fichier .pem — le backend lit le contenu :
#      JWT_PRIVATE_KEY=private.pem
#      JWT_PUBLIC_KEY=public.pem
# 2. (Prod) Coller le contenu PEM brut (commence par -----BEGIN).
JWT_PRIVATE_KEY=private.pem
JWT_PUBLIC_KEY=public.pem

# ── IA — Gemini (Vertex AI) ───────────────────────────────────
GEMINI_API_KEY=
GCP_PROJECT_ID=nexya-ai
GCP_LOCATION=us-central1

# ── IA — OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=

# ── IA — Qwen (Alibaba Cloud) ────────────────────────────────
QWEN_API_KEY=

# ── Storage (MinIO / S3) ──────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=nexya_minio
S3_SECRET_KEY=nexya_minio_secret
S3_BUCKET_NAME=nexya-media

# ── Paiements Afrique ─────────────────────────────────────────
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
NOTCHPAY_PUBLIC_KEY=
NOTCHPAY_SECRET_KEY=

# ── Paiements carte bancaire ──────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Notifications push ────────────────────────────────────────
FCM_SERVER_KEY=

# ── CORS ───────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
