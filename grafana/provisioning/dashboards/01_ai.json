{
  "uid": "nexya-ai",
  "title": "NEXYA — IA (chat / providers / coût)",
  "tags": ["nexya", "ai"],
  "schemaVersion": 39,
  "version": 1,
  "editable": false,
  "graphTooltip": 1,
  "time": {"from": "now-6h", "to": "now"},
  "refresh": "30s",
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "provider",
        "label": "Provider",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "nexya-prom"},
        "query": "label_values(nexya_ai_chat_calls_total, provider)",
        "multi": true,
        "includeAll": true,
        "refresh": 2
      },
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "nexya-prom"},
        "query": "label_values(nexya_ai_chat_calls_total{provider=~\"$provider\"}, model)",
        "multi": true,
        "includeAll": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "TTFB p50 / p95 / p99 par provider/model",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "nexya-prom"},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le, provider, model) (rate(nexya_ai_chat_first_chunk_seconds_bucket{provider=~\"$provider\",model=~\"$model\"}[5m])))",
          "legendFormat": "p50 {{provider}}/{{model}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le, provider, model) (rate(nexya_ai_chat_first_chunk_seconds_bucket{provider=~\"$provider\",model=~\"$model\"}[5m])))",
          "legendFormat": "p95 {{provider}}/{{model}}"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le, provider, model) (rate(nexya_ai_chat_first_chunk_seconds_bucket{provider=~\"$provider\",model=~\"$model\"}[5m])))",
          "legendFormat": "p99 {{provider}}/{{model}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Durée totale stream p50 / p95 / p99",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "nexya-prom"},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le, provider, model) (rate(nexya_ai_chat_total_duration_seconds_bucket{provider=~\"$provider\",model=~\"$model\"}[5m])))",
          "legendFormat": "p50 {{provider}}/{{model}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le, provider, model) (rate(nexya_ai_chat_total_duration_seconds_bucket{provider=~\"$provider\",model=~\"$model\"}[5m])))",
          "legendFormat": "p95 {{provider}}/{{model}}"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le, provider, model) (rate(nexya_ai_chat_total_duration_seconds_bucket{provider=~\"$provider\",model=~\"$model\"}[5m])))",
          "legendFormat": "p99 {{provider}}/{{model}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Tokens consommés / s par kind",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "nexya-prom"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (kind) (rate(nexya_ai_tokens_consumed_total{provider=~\"$provider\",model=~\"$model\"}[5m]))",
          "legendFormat": "{{kind}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Coût USD cumulé jour par provider",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "nexya-prom"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (provider) (increase(nexya_ai_cost_usd_total{provider=~\"$provider\"}[24h]))",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Échecs par error_type (1h)",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "nexya-prom"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (error_type) (rate(nexya_ai_provider_failures_total{provider=~\"$provider\",model=~\"$model\"}[1h]))",
          "legendFormat": "{{error_type}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Circuit breaker — état courant",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "nexya-prom"},
      "targets": [
        {
          "refId": "A",
          "expr": "nexya_ai_circuit_breaker_state{provider=~\"$provider\",model=~\"$model\"}",
          "legendFormat": "{{provider}}/{{model}}"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "closed", "color": "green"}, "1": {"text": "half_open", "color": "yellow"}, "2": {"text": "open", "color": "red"}}}], "unit": "short"}}
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Top 10 experts (24h)",
      "gridPos": {"x": 0, "y": 24, "w": 24, "h": 6},
      "datasource": {"type": "prometheus", "uid": "nexya-prom"},
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (expert_id) (increase(nexya_ai_chat_calls_total[24h])))",
          "legendFormat": "{{expert_id}}"
        }
      ],
      "options": {"orientation": "horizontal", "displayMode": "gradient"},
      "fieldConfig": {"defaults": {"unit": "short"}}
    }
  ]
}
