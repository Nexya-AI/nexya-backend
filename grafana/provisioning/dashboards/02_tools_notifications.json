{
  "uid": "nexya-tools-notifications",
  "title": "NEXYA — Tools & Notifications",
  "tags": ["nexya", "tools", "notifications"],
  "schemaVersion": 39,
  "version": 1,
  "editable": false,
  "graphTooltip": 1,
  "time": {"from": "now-6h", "to": "now"},
  "refresh": "30s",
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "tool_name",
        "label": "Tool",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "nexya-prom"},
        "query": "label_values(nexya_tools_executed_total, name)",
        "multi": true,
        "includeAll": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Tools executed / min par nom et succès",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "nexya-prom"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (name, success) (rate(nexya_tools_executed_total{name=~\"$tool_name\"}[1m]))",
          "legendFormat": "{{name}} success={{success}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Durée p95 tool execution",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "nexya-prom"},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, name) (rate(nexya_tools_execution_duration_seconds_bucket{name=~\"$tool_name\"}[5m])))",
          "legendFormat": "p95 {{name}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Taux succès tools global (5m)",
      "gridPos": {"x": 0, "y": 8, "w": 8, "h": 4},
      "datasource": {"type": "prometheus", "uid": "nexya-prom"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(nexya_tools_executed_total{success=\"true\"}[5m])) / clamp_min(sum(rate(nexya_tools_executed_total[5m])), 0.0001)",
          "legendFormat": "success rate"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "decimals": 3, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.9}, {"color": "green", "value": 0.98}]}}}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Notifications dispatchées par catégorie / canal",
      "gridPos": {"x": 8, "y": 8, "w": 16, "h": 8},
      "datasource": {"type": "prometheus", "uid": "nexya-prom"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (category, channel_used) (rate(nexya_notifications_dispatched_total[5m]))",
          "legendFormat": "{{category}} → {{channel_used}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Taux fallback push→email (5m)",
      "gridPos": {"x": 0, "y": 16, "w": 8, "h": 4},
      "datasource": {"type": "prometheus", "uid": "nexya-prom"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(nexya_notifications_dispatched_total{channel_used=\"email\"}[5m])) / clamp_min(sum(rate(nexya_notifications_dispatched_total[5m])), 0.0001)",
          "legendFormat": "fallback rate"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "decimals": 3}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Échecs FCM par error_type (1h)",
      "gridPos": {"x": 8, "y": 16, "w": 16, "h": 8},
      "datasource": {"type": "prometheus", "uid": "nexya-prom"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (error_type) (rate(nexya_notifications_fcm_failures_total[1h]))",
          "legendFormat": "{{error_type}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    }
  ]
}
